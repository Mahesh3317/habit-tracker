// Firestore Security Rules — Self Control Habit Tracker
//
// Core rule: a user can ONLY read and write their own data.
// No user can access another user's documents.
//
// How to deploy:
//   Option A (Firebase CLI):
//     npm install -g firebase-tools
//     firebase login
//     firebase init firestore      ← point to this rules file
//     firebase deploy --only firestore:rules
//
//   Option B (Firebase Console):
//     Firestore → Rules → paste these rules → Publish
//
// Free tier note:
//   Security rules do NOT count against your read/write quota.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profile document ────────────────────────────────────────────────
    // Path: users/{userId}
    // Contains: email, displayName, createdAt
    match /users/{userId} {
      // A user can read and write only their own profile
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // ── App state sub-document ─────────────────────────────────────────────
      // Path: users/{userId}/data/appState
      // Contains: the full serialised HabitContext state
      match /data/{document} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      // ── Any other sub-collections added in future ─────────────────────────
      match /{subcollection=**} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    // Any path not matched above is denied by default in Firestore,
    // but we make it explicit for clarity.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
