# Habit Tracker Environment Variables

# Expo Configuration (auto-loaded from app.json)
# These are typically set in app.json and eas.json, not here

# Local Development
EXPO_PUBLIC_API_URL=http://localhost:3000

# Analytics (optional)
# ANALYTICS_TOKEN=your_token_here

# Feature Flags
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=false
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# Debug Mode (set to false in production)
EXPO_PUBLIC_DEBUG=true
